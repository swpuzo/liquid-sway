# Waybar

# autotiling script
# https://github.com/nwg-piotr/autotiling
# `yay -S autotiling ;) (it is in AUR)
exec_always autotiling

# Gaps
gaps top 2
gaps inner 3
gaps outer 1

########################
# Remove Window Title Bars
########################
# Remove borders/title bars for all windows
for_window [class=".*"] border none

# Optional: minimal 1px border only for focused windows
# for_window [class=".*"] border pixel 1


include /etc/sway/config.d/*


# Screenshots
bindsym $mod+Shift+s exec --no-startup-id grim -g "$(slurp)" - | wl-copy && notify-send "Screenshot copied to clipboard"

# polkit-gnome
exec_always /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &

# Notification daemon
# exec_always mako &
# Start Sway Notification Center
exec_always swaync &

# Toggle the notification center panel (Mod + Shift + n)
bindsym $mod+Shift+n exec swaync-client -t -sw

# gnome-keyring
# exec --no-startup-id /usr/bin/gnome-keyring-daemon --start --components=secrets
# exec --no-startup-id dbus-launch /usr/bin/gnome-keyring-daemon --start --components=secrets

# Start GNOME Keyring services for secrets (and optionally ssh, pkcs11)
exec --no-startup-id /usr/bin/gnome-keyring-daemon --start --components=secrets,pkcs11

exec xhost +

# If you need SSH agent support via gcr (see note)
# exec --no-startup-id /usr/bin/gnome-keyring-daemon --start --components=ssh,secrets,pkcs11

# Allow legacy X11 apps to screenshare Wayland
exec_always xwaylandvideobridge

# enable pip in all windows
for_window [title="Picture-in-Picture"] sticky enable

# SwayFX
blur enable
blur_xray disable
blur_passes 3
blur_radius 7

blur_brightness 1
corner_radius 5
default_dim_inactive 0.15

exec_always "swaybg -i ~/Pictures/wallpaper.jpg -m fill"
exec_always "pkill -x waybar; waybar > /dev/null 2>&1 &"

input "type:keyboard" {
    xkb_layout "us,ru"
    xkb_options "grp:caps_toggle"
}
exec_always autotiling
# exec_always autotiling
blur enable
blur_passes 3
blur_radius 7
corner_radius 13
shadows {
    enabled yes
    blur 15
}
